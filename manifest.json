
{
  "name": "SteadySpreader",
  "version": "1.0",
  "description": "Spread Steady articles",
  "manifest_version": 2,
  "browser_specific_settings": {
    "gecko": {
      "id": "SteadySpreader@LarsTwiNky",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "browser_action": {
      "default_popup": "popup/popup.html",
      "default_icon": "popup/icon.png"
    },
  "permissions": ["storage"
  ],
  "content_scripts": [
      {
      "matches":[
          "https://steady.page/*"
      ],
      "js": ["content/content.js"],
      "css": ["content/content.css"]
      }
  ]
}